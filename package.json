{
  "name": "wellfit-emr",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.5.5",
      "next-themes": "^0.4.6",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "@orpc/client": "^1.13.14",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @wellfit-emr/db db:push",
    "db:studio": "turbo -F @wellfit-emr/db db:studio",
    "db:generate": "turbo -F @wellfit-emr/db db:generate",
    "db:migrate": "turbo -F @wellfit-emr/db db:migrate",
    "db:local": "turbo -F @wellfit-emr/db db:local",
    "seed": "cd packages/api && bun --env-file=../../apps/server/.env src/seed.ts",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@wellfit-emr/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "catalog:",
    "@wellfit-emr/config": "workspace:*",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.6.1"
  },
  "packageManager": "bun@1.3.12"
}
